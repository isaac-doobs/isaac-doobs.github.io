---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const d = project.data;
const { Content } = await render(project);

// Sequential section numbering — called in document order, skips absent sections
let _n = 0;
const sec = () => String(++_n).padStart(2, "0");

const hasDocs = d.academicContext || d.challenges || d.researchRelevance;
const statusClass = `status-${d.status.toLowerCase().replace(/\s+/g, "-")}`;

// Use a real still for the social card (most thumbnails are video). Falls back
// to the Layout default when no image asset is available.
const ogImage = [d.thumbnailUrl, ...(d.mediaGallery ?? [])].find((u) =>
  /\.(jpe?g|png|webp)$/i.test(u),
);
---

<Layout
  title={`${d.title} — Cristian Dubineanschi`}
  description={`${d.category} project by Cristian Dubineanschi — ${d.title}.`}
  image={ogImage}
>
  <!-- ============ HERO ============ -->
  <section class="immersive-hero" id="hero-section">
    <div class="hero-video-wrapper">
      {
        d.videoUrl.endsWith(".mp4") ? (
          <video autoplay muted loop playsinline id="hero-player">
            <source src={d.videoUrl} type="video/mp4" />
          </video>
        ) : (
          <img src={d.videoUrl} id="hero-player" alt={d.title} />
        )
      }
      <div class="hero-tint"></div>
    </div>

    <span class="hero-watermark" aria-hidden="true">{d.category}</span>

    <div class="hero-content container">
      <div class="hero-eyebrow-row reveal" style="--reveal-delay: .1s">
        <span class="he-cat">{d.category}</span>
        <span class="he-sep">/</span>
        <span class="he-year">{d.year}</span>
        <span class="he-sep">/</span>
        <span class={`he-status ${statusClass}`}>● {d.status.toUpperCase()}</span>
      </div>

      <h1 class="hero-title">
        <span class="line-mask" style="--reveal-delay: .2s">
          <span data-edit-field="title">{d.title}</span>
          {project.id === "oracolul2000" && <span class="title-collab">(collaboration)</span>}
          {project.id === "rooted-structures" && <span class="title-collab">(team project)</span>}
        </span>
      </h1>

      <div class="hero-meta-strip reveal" style="--reveal-delay: .5s">
        {d.medium.map((m) => <span class="hm-tag">{m}</span>)}
      </div>
    </div>

    <a href="#body" class="hero-scroll-cue" data-magnetic data-magnetic-strength="0.4">
      <span>SCROLL</span><span class="hsc-arrow">↓</span>
    </a>
  </section>

  <div class="spec-container container" id="body">
    <!-- ============ CONCEPT + SPEC ============ -->
    <section class="split-section">
      <div class="split-left reveal">
        <div class="block-header">
          <span class="block-num">{sec()}</span><h2 class="block-title">Concept</h2>
        </div>
        <div class="concept-paragraph" data-edit-field="concept">{d.concept}</div>
        <div class="markdown-extra"><Content /></div>
      </div>

      <div class="split-right reveal" style="--reveal-delay: .12s">
        <div class="block-header">
          <span class="block-num">{sec()}</span><h2 class="block-title">Specification</h2>
        </div>
        <dl class="spec-table">
          <div class="spec-row"><dt>ID</dt><dd class="upper">{project.id}</dd></div>
          <div class="spec-row"><dt>Year</dt><dd data-edit-field="year">{d.year}</dd></div>
          <div class="spec-row">
            <dt>Category</dt><dd data-edit-field="category">{d.category}</dd>
          </div>
          <div class="spec-row">
            <dt>Status</dt><dd class={`upper ${statusClass}`} data-edit-field="status">
              {d.status}
            </dd>
          </div>
          {
            d.dimensions && (
              <div class="spec-row">
                <dt>Dimensions</dt>
                <dd data-edit-field="dimensions">{d.dimensions}</dd>
              </div>
            )
          }
          <div class="spec-row">
            <dt>Software</dt>
            <dd class="tags">
              <span class="tags-container">
                {
                  d.software.map((s) => (
                    <span class="tag" data-edit-spec-tag="software">
                      {s}
                    </span>
                  ))
                }
              </span>
              <span class="add-tag-btn" data-add-tag-for="software" style="display: none;">+</span>
            </dd>
          </div>
          <div class="spec-row">
            <dt>Hardware</dt>
            <dd class="tags">
              <span class="tags-container">
                {
                  d.hardware.map((s) => (
                    <span class="tag" data-edit-spec-tag="hardware">
                      {s}
                    </span>
                  ))
                }
              </span>
              <span class="add-tag-btn" data-add-tag-for="hardware" style="display: none;">+</span>
            </dd>
          </div>
          <div class="spec-row">
            <dt>Inputs</dt>
            <dd class="tags">
              <span class="tags-container">
                {
                  d.inputs.map((s) => (
                    <span class="tag" data-edit-spec-tag="inputs">
                      {s}
                    </span>
                  ))
                }
              </span>
              <span class="add-tag-btn" data-add-tag-for="inputs" style="display: none;">+</span>
            </dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- ============ SCHEMATIC + PROCESS ============ -->
    {
      d.blueprintUrl && d.process && d.process.length > 0 ? (
        <section class="split-section">
          <div class="split-left reveal">
            <div class="block-header">
              <>
                <span class="block-num">{sec()}</span>
                <h2 class="block-title">Schematic</h2>
              </>
            </div>
            <figure class="blueprint-frame">
              <div class="blueprint-media">
                <img
                  src={d.blueprintUrl}
                  alt={d.blueprintCaption || "System schematic"}
                  class="blueprint-img"
                />
              </div>
              {d.blueprintCaption && (
                <figcaption class="blueprint-caption font-mono">
                  FIG. — {d.blueprintCaption}
                </figcaption>
              )}
            </figure>
          </div>

          <div class="split-right reveal" style="--reveal-delay: .12s">
            <div class="block-header">
              <>
                <span class="block-num">{sec()}</span>
                <h2 class="block-title">Process</h2>
              </>
            </div>
            <ol class="steps">
              {d.process.map((step, i) => (
                <li class="step">
                  <span class="step-num">{String(i + 1).padStart(2, "0")}</span>
                  <span class="step-rule" />
                  <p class="step-body" data-edit-step-index={i}>
                    {step}
                  </p>
                </li>
              ))}
            </ol>
          </div>
        </section>
      ) : (
        <>
          {d.blueprintUrl && (
            <section class="block-section reveal">
              <div class="block-header">
                <span class="block-num">{sec()}</span>
                <h2 class="block-title">Schematic</h2>
              </div>
              <figure class="blueprint-frame">
                <div class="blueprint-media">
                  <img
                    src={d.blueprintUrl}
                    alt={d.blueprintCaption || "System schematic"}
                    class="blueprint-img"
                  />
                </div>
                {d.blueprintCaption && (
                  <figcaption class="blueprint-caption font-mono">
                    FIG. — {d.blueprintCaption}
                  </figcaption>
                )}
              </figure>
            </section>
          )}

          {d.process && d.process.length > 0 && (
            <section class="block-section reveal">
              <div class="block-header">
                <span class="block-num">{sec()}</span>
                <h2 class="block-title">Process</h2>
              </div>
              <ol class="steps">
                {d.process.map((step, i) => (
                  <li class="step">
                    <span class="step-num">{String(i + 1).padStart(2, "0")}</span>
                    <span class="step-rule" />
                    <p class="step-body" data-edit-step-index={i}>
                      {step}
                    </p>
                  </li>
                ))}
              </ol>
            </section>
          )}
        </>
      )
    }

    <!-- ============ DOCUMENTATION ============ -->
    {
      hasDocs && (
        <section class="block-section reveal">
          <div class="block-header">
            <>
              <span class="block-num">{sec()}</span>
              <h2 class="block-title">Research &amp; Documentation</h2>
            </>
          </div>
          <div class="docs-grid">
            {d.academicContext && (
              <div class="doc-block">
                <h3 class="doc-label">Context</h3>
                <p class="doc-text" data-edit-field="academicContext">
                  {d.academicContext}
                </p>
              </div>
            )}
            {d.challenges && (
              <div class="doc-block">
                <h3 class="doc-label">Challenges &amp; Solutions</h3>
                <p class="doc-text" data-edit-field="challenges">
                  {d.challenges}
                </p>
              </div>
            )}
            {d.researchRelevance && (
              <div class="doc-block">
                <h3 class="doc-label">Research Relevance</h3>
                <p class="doc-text" data-edit-field="researchRelevance">
                  {d.researchRelevance}
                </p>
              </div>
            )}
          </div>
        </section>
      )
    }

    <!-- ============ VISUAL DOCUMENTATION ============ -->
    {
      d.mediaGallery && d.mediaGallery.length > 0 && (
        <section class="block-section reveal">
          <div class="block-header">
            <>
              <span class="block-num">{sec()}</span>
              <h2 class="block-title">Visual Documentation</h2>
            </>
          </div>
          <div class="gallery-grid">
            {d.mediaGallery.map((url) => {
              const isVideo = /\.(mp4|webm|mov)$/i.test(url);
              // Heavy clips are not auto-loaded in the grid: we show a lightweight
              // poster still (convention: same path with `_poster.jpg`) and only fetch
              // the full video — with sound — when the visitor opens the lightbox.
              const poster = url.replace(/\.(mp4|webm|mov)$/i, "_poster.jpg");
              return (
                <button
                  type="button"
                  class="gallery-item"
                  data-media-src={url}
                  data-media-type={isVideo ? "video" : "image"}
                  aria-label={isVideo ? "Play video fullscreen" : "View image fullscreen"}
                >
                  <img
                    src={isVideo ? poster : url}
                    alt="Visual documentation"
                    class="gallery-img"
                    loading="lazy"
                  />
                  <span class="gallery-zoom" aria-hidden="true">
                    {isVideo ? "▶" : "⤢"}
                  </span>
                </button>
              );
            })}
          </div>
        </section>
      )
    }

    <!-- ============ BACK ============ -->
    <a href="/" class="back-link" data-magnetic data-magnetic-strength="0.3">← All works</a>
  </div>

  <!-- ============ MEDIA LIGHTBOX (swipeable photo/video viewer) ============ -->
  <div
    class="media-lightbox"
    id="media-lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Media viewer"
    hidden
  >
    <button class="lightbox-close" id="lightbox-close" type="button" aria-label="Close viewer">
      ✕
    </button>
    <button
      class="lightbox-nav lightbox-prev"
      id="lightbox-prev"
      type="button"
      aria-label="Previous"
    >
      ‹
    </button>
    <div class="lightbox-track" id="lightbox-track"></div>
    <button class="lightbox-nav lightbox-next" id="lightbox-next" type="button" aria-label="Next">
      ›
    </button>
    <span class="lightbox-counter font-mono" id="lightbox-counter"></span>
  </div>
</Layout>

<script>
  // Tap any gallery item to open a fullscreen, swipeable viewer of all of the
  // project's media. Photos and videos share one track — swipe (touch), the
  // arrows, or the ← / → keys move between them. Videos are silent, with
  // native controls, and don't download until shown; only the visible one plays.
  function initGallery() {
    const lightbox = document.getElementById("media-lightbox") as HTMLElement | null;
    const track = document.getElementById("lightbox-track");
    const closeBtn = document.getElementById("lightbox-close");
    const prevBtn = document.getElementById("lightbox-prev") as HTMLButtonElement | null;
    const nextBtn = document.getElementById("lightbox-next") as HTMLButtonElement | null;
    const counter = document.getElementById("lightbox-counter");
    const items = Array.from(document.querySelectorAll<HTMLElement>(".gallery-item"));
    if (!lightbox || !track || !closeBtn || !prevBtn || !nextBtn || !counter || items.length === 0)
      return;

    const media = items.map((it) => ({
      src: it.dataset.mediaSrc || "",
      type: it.dataset.mediaType || "image",
      poster: it.querySelector("img")?.getAttribute("src") || "",
    }));
    const multiple = media.length > 1;
    let lastFocused: HTMLElement | null = null;
    let current = 0;
    let built = false;

    function buildSlides() {
      if (!track) return;
      track.innerHTML = "";
      media.forEach((m) => {
        const slide = document.createElement("div");
        slide.className = "lightbox-slide";
        if (m.type === "video") {
          const video = document.createElement("video");
          video.src = m.src;
          if (m.poster) video.poster = m.poster;
          video.controls = true;
          video.loop = true;
          video.muted = true; // videos carry no audio; muted also allows autoplay
          video.playsInline = true;
          video.preload = "none";
          slide.appendChild(video);
        } else {
          const img = document.createElement("img");
          img.src = m.src;
          img.alt = "Visual documentation";
          slide.appendChild(img);
        }
        track.appendChild(slide);
      });
      built = true;
    }

    function setActive(i: number) {
      if (!track) return;
      current = Math.max(0, Math.min(media.length - 1, i));
      Array.from(track.children).forEach((slide, si) => {
        const v = slide.querySelector("video");
        if (!v) return;
        if (si === current) v.play().catch(() => {});
        else v.pause();
      });
      if (counter) counter.textContent = `${current + 1} / ${media.length}`;
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current === media.length - 1;
    }

    function goTo(i: number, smooth: boolean) {
      if (!track) return;
      track.scrollTo({ left: i * track.clientWidth, behavior: smooth ? "smooth" : "auto" });
    }

    function open(index: number) {
      if (!lightbox || !track || !closeBtn) return;
      if (!built) buildSlides();
      lastFocused = document.activeElement as HTMLElement;
      lightbox.hidden = false;
      const navDisplay = multiple ? "" : "none";
      if (prevBtn) prevBtn.style.display = navDisplay;
      if (nextBtn) nextBtn.style.display = navDisplay;
      if (counter) counter.style.display = navDisplay;
      requestAnimationFrame(() => {
        lightbox.classList.add("is-open");
        goTo(index, false);
        setActive(index);
      });
      document.body.style.overflow = "hidden";
      document.body.classList.add("lightbox-open");
      closeBtn.focus();
    }

    function close() {
      if (!lightbox || !track) return;
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
      document.body.classList.remove("lightbox-open");
      track.querySelectorAll("video").forEach((v) => v.pause());
      window.setTimeout(() => {
        lightbox.hidden = true;
      }, 300);
      if (lastFocused && typeof lastFocused.focus === "function") lastFocused.focus();
    }

    // Track the active slide as the viewer is swiped/scrolled.
    let ticking = false;
    track.addEventListener(
      "scroll",
      () => {
        if (ticking || !track) return;
        ticking = true;
        requestAnimationFrame(() => {
          if (track) setActive(Math.round(track.scrollLeft / track.clientWidth));
          ticking = false;
        });
      },
      { passive: true },
    );

    items.forEach((item, i) => item.addEventListener("click", () => open(i)));
    prevBtn.addEventListener("click", () => goTo(current - 1, true));
    nextBtn.addEventListener("click", () => goTo(current + 1, true));
    closeBtn.addEventListener("click", close);
    // Tap the dim backdrop around a slide to close.
    track.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).classList.contains("lightbox-slide")) close();
    });
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });
  }

  // Global keyboard control, bound once. Resolves the live lightbox each time so
  // it keeps working across view-transition page swaps.
  if (!(window as any).__galleryKeysBound) {
    (window as any).__galleryKeysBound = true;
    document.addEventListener("keydown", (e) => {
      const lb = document.getElementById("media-lightbox");
      if (!lb || lb.hidden) return;
      if (e.key === "Escape") document.getElementById("lightbox-close")?.click();
      else if (e.key === "ArrowLeft") document.getElementById("lightbox-prev")?.click();
      else if (e.key === "ArrowRight") document.getElementById("lightbox-next")?.click();
    });
  }

  // Honour prefers-reduced-motion: freeze the looping hero background video.
  function respectReducedMotion() {
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    document.querySelectorAll<HTMLVideoElement>("video[autoplay]").forEach((v) => {
      v.removeAttribute("autoplay");
      v.pause();
    });
  }

  function init() {
    initGallery();
    respectReducedMotion();
  }

  init();
  document.addEventListener("astro:after-swap", init);
</script>

<style>
  /* ============ HERO ============ */
  .immersive-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 5rem;
    background: var(--color-bg);
    overflow: hidden;
  }
  .hero-video-wrapper {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .hero-video-wrapper video,
  .hero-video-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
    filter: grayscale(1) contrast(1.05);
  }
  .hero-tint {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(to bottom, rgba(10, 10, 10, 0.5) 0%, transparent 30%, var(--color-bg) 97%),
      linear-gradient(to right, rgba(10, 10, 10, 0.6) 0%, transparent 55%);
  }
  .hero-watermark {
    position: absolute;
    top: 14vh;
    right: -1vw;
    z-index: 2;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(3.5rem, 11vw, 10rem);
    line-height: 0.8;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: var(--color-text);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
  }
  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
  }
  .hero-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    margin-bottom: 1.4rem;
  }
  .hero-eyebrow-row span {
    font-size: inherit;
    letter-spacing: inherit;
  }
  .he-cat {
    color: var(--color-accent);
    font-weight: 700;
    text-transform: uppercase;
  }
  .he-sep {
    color: var(--color-border);
  }
  .he-year {
    color: var(--color-muted);
  }
  .he-status.status-operational,
  .he-status.status-active {
    color: var(--color-success);
  }
  .he-status.status-archived {
    color: var(--color-muted);
  }
  .he-status.status-in-development {
    color: var(--color-warning);
  }

  .hero-title {
    margin: 0;
  }
  .hero-title .line-mask,
  .hero-title .line-mask > span {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .title-collab {
    font-size: clamp(1rem, 2.5vw, 2rem);
    opacity: 0.4;
    font-family: var(--font-mono);
    font-weight: normal;
    text-transform: uppercase;
    margin-left: 1rem;
    vertical-align: middle;
    letter-spacing: 0.05em;
  }
  .hero-meta-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.8rem;
  }
  .hm-tag {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-muted-lavender);
    border: 1px solid var(--color-border);
    padding: 5px 11px;
  }
  .hero-scroll-cue {
    position: absolute;
    right: 2rem;
    bottom: 2rem;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: var(--color-muted);
  }
  .hero-scroll-cue span {
    font-size: inherit;
    letter-spacing: inherit;
    color: inherit;
  }
  .hsc-arrow {
    color: var(--color-accent);
    font-size: 0.95rem;
    animation: bounce 1.5s infinite alternate;
  }
  @keyframes bounce {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(6px);
    }
  }

  /* ============ LAYOUT ============ */
  .spec-container {
    padding-top: 6rem;
    padding-bottom: 7rem;
  }
  .block-section {
    margin-bottom: 6rem;
  }
  .block-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    margin-bottom: 2.5rem;
  }
  .block-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 400;
  }
  .block-title {
    font-family: var(--font-sans);
    font-size: clamp(1.2rem, 2vw, 1.7rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  /* Concept + Spec split */
  .split-section {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    margin-bottom: 6rem;
  }
  .concept-paragraph {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-muted-lavender);
    margin-bottom: 2rem;
    white-space: pre-line;
  }
  .markdown-extra :global(h3) {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    margin: 2rem 0 0.75rem;
    color: var(--color-text);
  }
  .markdown-extra :global(p) {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-muted-lavender);
    margin-bottom: 1rem;
    line-height: 1.7;
  }
  .markdown-extra :global(pre) {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    padding: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.72rem;
    overflow-x: auto;
    color: var(--color-muted-lavender);
