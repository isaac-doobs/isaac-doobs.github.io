---
import { getCollection, render } from "astro:content";
import { Code } from "astro:components";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const d = project.data;
const { Content } = await render(project);

// Sequential section numbering — called in document order, skips absent sections
let _n = 0;
const sec = () => String(++_n).padStart(2, "0");

const hasDocs = d.academicContext || d.challenges || d.researchRelevance;
const statusClass = `status-${d.status.toLowerCase().replace(/\s+/g, "-")}`;

// Use a real still for the social card (most thumbnails are video). Falls back
// to the Layout default when no image asset is available.
const ogImage = [d.thumbnailUrl, ...(d.mediaGallery ?? [])].find((u) =>
  /\.(jpe?g|png|webp)$/i.test(u),
);
---

<Layout
  title={`${d.title} — Cristian Dubineanschi`}
  description={`${d.category} project by Cristian Dubineanschi — ${d.title}.`}
  image={ogImage}
>
  <!-- ============ HERO ============ -->
  <section class="immersive-hero" id="hero-section">
    <div class="hero-video-wrapper">
      {
        d.videoUrl.endsWith(".mp4") ? (
          <video autoplay muted loop playsinline id="hero-player">
            <source src={d.videoUrl} type="video/mp4" />
          </video>
        ) : (
          <img src={d.videoUrl} id="hero-player" alt={d.title} />
        )
      }
      <div class="hero-tint"></div>
    </div>

    <span class="hero-watermark" aria-hidden="true">{d.category}</span>

    <div class="hero-content container">
      <div class="hero-eyebrow-row reveal" style="--reveal-delay: .1s">
        <span class="he-cat">{d.category}</span>
        <span class="he-sep">/</span>
        <span class="he-year">{d.year}</span>
        <span class="he-sep">/</span>
        <span class={`he-status ${statusClass}`}>● {d.status.toUpperCase()}</span>
      </div>

      <h1 class="hero-title">
        <span class="line-mask" style="--reveal-delay: .2s">
          <span data-edit-field="title">{d.title}</span>
          {project.id === "oracolul2000" && <span class="title-collab">(collaboration)</span>}
          {project.id === "rooted-structures" && <span class="title-collab">(team project)</span>}
        </span>
      </h1>

      <div class="hero-meta-strip reveal" style="--reveal-delay: .5s">
        {d.medium.map((m) => <span class="hm-tag">{m}</span>)}
      </div>
    </div>

    <a href="#body" class="hero-scroll-cue" data-magnetic data-magnetic-strength="0.4">
      <span>SCROLL</span><span class="hsc-arrow">↓</span>
    </a>
  </section>

  <div class="spec-container container" id="body">
    <!-- ============ CONCEPT + SPEC ============ -->
    <section class="split-section">
      <div class="split-left reveal">
        <div class="block-header">
          <span class="block-num">{sec()}</span><h2 class="block-title">Concept</h2>
        </div>
        <div class="concept-paragraph" data-edit-field="concept">{d.concept}</div>
        <div class="markdown-extra"><Content /></div>
      </div>

      <div class="split-right reveal" style="--reveal-delay: .12s">
        <div class="block-header">
          <span class="block-num">{sec()}</span><h2 class="block-title">Specification</h2>
        </div>
        <dl class="spec-table">
          <div class="spec-row"><dt>ID</dt><dd class="upper">{project.id}</dd></div>
          <div class="spec-row"><dt>Year</dt><dd data-edit-field="year">{d.year}</dd></div>
          <div class="spec-row">
            <dt>Category</dt><dd data-edit-field="category">{d.category}</dd>
          </div>
          <div class="spec-row">
            <dt>Status</dt><dd class={`upper ${statusClass}`} data-edit-field="status">
              {d.status}
            </dd>
          </div>
          <div class="spec-row">
            <dt>Software</dt>
            <dd class="tags">
              <span class="tags-container">
                {
                  d.software.map((s) => (
                    <span class="tag" data-edit-spec-tag="software">
                      {s}
                    </span>
                  ))
                }
              </span>
              <span class="add-tag-btn" data-add-tag-for="software" style="display: none;">+</span>
            </dd>
          </div>
          <div class="spec-row">
            <dt>Hardware</dt>
            <dd class="tags">
              <span class="tags-container">
                {
                  d.hardware.map((s) => (
                    <span class="tag" data-edit-spec-tag="hardware">
                      {s}
                    </span>
                  ))
                }
              </span>
              <span class="add-tag-btn" data-add-tag-for="hardware" style="display: none;">+</span>
            </dd>
          </div>
          <div class="spec-row">
            <dt>Inputs</dt>
            <dd class="tags">
              <span class="tags-container">
                {
                  d.inputs.map((s) => (
                    <span class="tag" data-edit-spec-tag="inputs">
                      {s}
                    </span>
                  ))
                }
              </span>
              <span class="add-tag-btn" data-add-tag-for="inputs" style="display: none;">+</span>
            </dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- ============ SCHEMATIC + PROCESS ============ -->
    {
      d.blueprintUrl && d.process && d.process.length > 0 ? (
        <section class="split-section">
          <div class="split-left reveal">
            <div class="block-header">
              <>
                <span class="block-num">{sec()}</span>
                <h2 class="block-title">Schematic</h2>
              </>
            </div>
            <figure class="blueprint-frame">
              <div class="blueprint-media">
                <img
                  src={d.blueprintUrl}
                  alt={d.blueprintCaption || "System schematic"}
                  class="blueprint-img"
                />
              </div>
              {d.blueprintCaption && (
                <figcaption class="blueprint-caption font-mono">
                  FIG. — {d.blueprintCaption}
                </figcaption>
              )}
            </figure>
          </div>

          <div class="split-right reveal" style="--reveal-delay: .12s">
            <div class="block-header">
              <>
                <span class="block-num">{sec()}</span>
                <h2 class="block-title">Process</h2>
              </>
            </div>
            <ol class="steps">
              {d.process.map((step, i) => (
                <li class="step">
                  <span class="step-num">{String(i + 1).padStart(2, "0")}</span>
                  <span class="step-rule" />
                  <p class="step-body" data-edit-step-index={i}>
                    {step}
                  </p>
                </li>
              ))}
            </ol>
          </div>
        </section>
      ) : (
        <>
          {d.blueprintUrl && (
            <section class="block-section reveal">
              <div class="block-header">
                <span class="block-num">{sec()}</span>
                <h2 class="block-title">Schematic</h2>
              </div>
              <figure class="blueprint-frame">
                <div class="blueprint-media">
                  <img
                    src={d.blueprintUrl}
                    alt={d.blueprintCaption || "System schematic"}
                    class="blueprint-img"
                  />
                </div>
                {d.blueprintCaption && (
                  <figcaption class="blueprint-caption font-mono">
                    FIG. — {d.blueprintCaption}
                  </figcaption>
                )}
              </figure>
            </section>
          )}

          {d.process && d.process.length > 0 && (
            <section class="block-section reveal">
              <div class="block-header">
                <span class="block-num">{sec()}</span>
                <h2 class="block-title">Process</h2>
              </div>
              <ol class="steps">
                {d.process.map((step, i) => (
                  <li class="step">
                    <span class="step-num">{String(i + 1).padStart(2, "0")}</span>
                    <span class="step-rule" />
                    <p class="step-body" data-edit-step-index={i}>
                      {step}
                    </p>
                  </li>
                ))}
              </ol>
            </section>
          )}
        </>
      )
    }

    <!-- ============ DOCUMENTATION ============ -->
    {
      hasDocs && (
        <section class="block-section reveal">
          <div class="block-header">
            <>
              <span class="block-num">{sec()}</span>
              <h2 class="block-title">Research &amp; Documentation</h2>
            </>
          </div>
          <div class="docs-grid">
            {d.academicContext && (
              <div class="doc-block">
                <h3 class="doc-label">Context</h3>
                <p class="doc-text" data-edit-field="academicContext">
                  {d.academicContext}
                </p>
              </div>
            )}
            {d.challenges && (
              <div class="doc-block">
                <h3 class="doc-label">Challenges &amp; Solutions</h3>
                <p class="doc-text" data-edit-field="challenges">
                  {d.challenges}
                </p>
              </div>
            )}
            {d.researchRelevance && (
              <div class="doc-block">
                <h3 class="doc-label">Research Relevance</h3>
                <p class="doc-text" data-edit-field="researchRelevance">
                  {d.researchRelevance}
                </p>
              </div>
            )}
          </div>
        </section>
      )
    }

    <!-- ============ VISUAL DOCUMENTATION ============ -->
    {
      d.mediaGallery && d.mediaGallery.length > 0 && (
        <section class="block-section reveal">
          <div class="block-header">
            <>
              <span class="block-num">{sec()}</span>
              <h2 class="block-title">Visual Documentation</h2>
            </>
          </div>
          <div class="gallery-grid">
            {d.mediaGallery.map((url) => {
              const isVideo = url.endsWith(".mp4");
              return (
                <button
                  type="button"
                  class="gallery-item"
                  data-media-src={url}
                  data-media-type={isVideo ? "video" : "image"}
                  aria-label={isVideo ? "Play video fullscreen" : "View image fullscreen"}
                >
                  {isVideo ? (
                    <video autoplay muted loop playsinline class="gallery-img">
                      <source src={url} type="video/mp4" />
                    </video>
                  ) : (
                    <img src={url} alt="Visual documentation" class="gallery-img" loading="lazy" />
                  )}
                  <span class="gallery-zoom" aria-hidden="true">
                    {isVideo ? "▶" : "⤢"}
                  </span>
                </button>
              );
            })}
          </div>
        </section>
      )
    }

    <!-- ============ CODE ============ -->
    {
      d.codeSnippet && (
        <section class="block-section reveal">
          <div class="block-header">
            <>
              <span class="block-num">{sec()}</span>
              <h2 class="block-title">Source</h2>
            </>
          </div>
          <div class="code-terminal collapsed" id="terminal-wrapper">
            <button class="terminal-header" id="terminal-toggle-btn" aria-expanded="false">
              <span class="terminal-title font-mono" id="terminal-status-title">
                VIEW SOURCE — {d.codeLanguage}
              </span>
              <span class="terminal-arrow" id="toggle-indicator">
                EXPAND [+]
              </span>
            </button>
            <div class="terminal-body" id="terminal-content">
              <div class="shiki-code-wrapper">
                <Code code={d.codeSnippet} lang={d.codeLanguage} theme="github-dark" />
              </div>
            </div>
          </div>
        </section>
      )
    }

    <!-- ============ BACK ============ -->
    <a href="/" class="back-link" data-magnetic data-magnetic-strength="0.3">← All works</a>
  </div>

  <!-- Live Edit HUD (Only visible on localhost) -->
  <div id="live-edit-hud" class="live-edit-hud" style="display: none;">
    <button id="live-edit-toggle-btn" class="hud-btn font-mono">[EDIT LIVE]</button>
    <div id="hud-actions" class="hud-actions hidden">
      <span id="hud-log" class="hud-status font-mono">>>> EDIT ACTIVE</span>
      <button id="live-edit-save-btn" class="hud-btn save font-mono">[SAVE]</button>
      <button id="live-edit-cancel-btn" class="hud-btn cancel font-mono">[CANCEL]</button>
    </div>
  </div>

  <!-- ============ MEDIA LIGHTBOX ============ -->
  <div
    class="media-lightbox"
    id="media-lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Media viewer"
    hidden
  >
    <button class="lightbox-close" id="lightbox-close" type="button" aria-label="Close viewer">
      ✕
    </button>
    <div class="lightbox-stage" id="lightbox-stage"></div>
  </div>

  <script
    id="project-data-json"
    type="application/json"
    set:html={JSON.stringify({ id: project.id, data: project.data, body: project.body || "" })}
  />
</Layout>

<script>
  function initTerminal() {
    const toggleBtn = document.getElementById("terminal-toggle-btn");
    const wrap = document.getElementById("terminal-wrapper");
    const ind = document.getElementById("toggle-indicator");
    if (!toggleBtn || !wrap || !ind) return;
    toggleBtn.addEventListener("click", () => {
      const collapsed = wrap.classList.toggle("collapsed");
      ind.textContent = collapsed ? "EXPAND [+]" : "COLLAPSE [-]";
      toggleBtn.setAttribute("aria-expanded", String(!collapsed));
    });
  }

  function initLiveEdit() {
    const hud = document.getElementById("live-edit-hud");
    const toggleBtn = document.getElementById("live-edit-toggle-btn");
    const actions = document.getElementById("hud-actions");
    const saveBtn = document.getElementById("live-edit-save-btn");
    const cancelBtn = document.getElementById("live-edit-cancel-btn");
    const log = document.getElementById("hud-log");
    const jsonEl = document.getElementById("project-data-json");

    if (!hud || !toggleBtn || !actions || !saveBtn || !cancelBtn || !jsonEl) return;

    if (window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1") {
      hud.style.display = "flex";
    } else {
      hud.style.display = "none";
      return;
    }

    let isEditing = false;
    const projectData = JSON.parse(jsonEl.textContent);

    const editableElements = {
      title: document.querySelector('[data-edit-field="title"]'),
      concept: document.querySelector('[data-edit-field="concept"]'),
      academicContext: document.querySelector('[data-edit-field="academicContext"]'),
      challenges: document.querySelector('[data-edit-field="challenges"]'),
      researchRelevance: document.querySelector('[data-edit-field="researchRelevance"]'),
      year: document.querySelector('[data-edit-field="year"]'),
      category: document.querySelector('[data-edit-field="category"]'),
      status: document.querySelector('[data-edit-field="status"]'),
    };

    const getStepElements = () => document.querySelectorAll("[data-edit-step-index]");
    const getSpecTags = () => document.querySelectorAll("[data-edit-spec-tag]");

    function toggleEditMode(active) {
      isEditing = active;
      if (active) {
        toggleBtn.classList.add("hidden");
        actions.classList.remove("hidden");
        log.textContent = ">>> EDIT ACTIVE";
        log.className = "hud-status font-mono";

        Object.values(editableElements).forEach((el) => {
          if (el) el.setAttribute("contenteditable", "true");
        });
        getStepElements().forEach((el) => {
          el.setAttribute("contenteditable", "true");
        });
        getSpecTags().forEach((el) => {
          el.setAttribute("contenteditable", "true");
        });

        const addBtns = document.querySelectorAll("[data-add-tag-for]");
        addBtns.forEach((btn) => {
          btn.style.display = "inline-flex";
        });
      } else {
        toggleBtn.classList.remove("hidden");
        actions.classList.add("hidden");

        Object.values(editableElements).forEach((el) => {
          if (el) el.removeAttribute("contenteditable");
        });
        getStepElements().forEach((el) => {
          el.removeAttribute("contenteditable");
        });
        getSpecTags().forEach((el) => {
          el.removeAttribute("contenteditable");
        });

        const addBtns = document.querySelectorAll("[data-add-tag-for]");
        addBtns.forEach((btn) => {
          btn.style.display = "none";
        });
      }
    }

    // Connect Add Tag buttons
    const addTagBtns = document.querySelectorAll("[data-add-tag-for]");
    addTagBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const type = btn.getAttribute("data-add-tag-for");
        const container = btn.parentElement.querySelector(".tags-container");
        if (container) {
          const newTag = document.createElement("span");
          newTag.className = "tag";
          newTag.setAttribute("data-edit-spec-tag", type);
          newTag.setAttribute("contenteditable", "true");
          newTag.textContent = "NEW";
          container.appendChild(newTag);
          newTag.focus();

          const range = document.createRange();
          range.selectNodeContents(newTag);
          const sel = window.getSelection();
          sel.removeAllRanges();
          sel.addRange(range);
        }
      });
    });

    toggleBtn.addEventListener("click", () => toggleEditMode(true));
    cancelBtn.addEventListener("click", () => {
      toggleEditMode(false);
      window.location.reload();
    });

    saveBtn.addEventListener("click", async () => {
      log.textContent = ">>> SAVING CHANGES...";
      log.className = "hud-status font-mono text-purple";

      if (editableElements.title)
        projectData.data.title = editableElements.title.textContent.trim();
      if (editableElements.concept)
        projectData.data.concept = editableElements.concept.textContent.trim();
      if (editableElements.academicContext)
        projectData.data.academicContext = editableElements.academicContext.textContent.trim();
      if (editableElements.challenges)
        projectData.data.challenges = editableElements.challenges.textContent.trim();
      if (editableElements.researchRelevance)
        projectData.data.researchRelevance = editableElements.researchRelevance.textContent.trim();
      if (editableElements.year)
        projectData.data.year = Number(editableElements.year.textContent.trim());
      if (editableElements.category)
        projectData.data.category = editableElements.category.textContent.trim();
      if (editableElements.status)
        projectData.data.status = editableElements.status.textContent.trim();

      const getTags = (type) => {
        return Array.from(document.querySelectorAll(`[data-edit-spec-tag="${type}"]`))
          .map((el) => el.textContent.trim())
          .filter(Boolean);
      };
      projectData.data.software = getTags("software");
      projectData.data.hardware = getTags("hardware");
      projectData.data.inputs = getTags("inputs");

      const steps = [];
      const stepEls = Array.from(getStepElements());
      stepEls.sort(
        (a, b) =>
          parseInt(a.getAttribute("data-edit-step-index")) -
          parseInt(b.getAttribute("data-edit-step-index")),
      );
      stepEls.forEach((el) => {
        steps.push(el.textContent.trim());
      });
      if (steps.length > 0) {
        projectData.data.process = steps;
      }

      try {
        const response = await fetch("http://localhost:4322/api/projects/save", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            id: projectData.id,
            data: projectData.data,
            body: projectData.body,
          }),
        });

        if (response.ok) {
          log.textContent = ">>> DISK WRITE OK [200]";
          log.className = "hud-status font-mono text-green";
          setTimeout(() => {
            toggleEditMode(false);
            window.location.reload();
          }, 1000);
        } else {
          const errData = await response.json();
          throw new Error(errData.error || "Failed to save");
        }
      } catch (err) {
        log.textContent = `>>> ERROR: ${err.message.toUpperCase()}`;
        log.className = "hud-status font-mono text-red";
      }
    });
  }

  // Click a gallery thumbnail to open the media in a fullscreen lightbox.
  // Videos open with sound + native controls; images open at full size.
  function initGallery() {
    const lightbox = document.getElementById("media-lightbox") as HTMLElement | null;
    const stage = document.getElementById("lightbox-stage");
    const closeBtn = document.getElementById("lightbox-close");
    const items = document.querySelectorAll<HTMLElement>(".gallery-item");
    if (!lightbox || !stage || !closeBtn || items.length === 0) return;

    let lastFocused: HTMLElement | null = null;

    function openMedia(src: string, type: string) {
      if (!lightbox || !stage || !closeBtn) return;
      stage.innerHTML = "";

      if (type === "video") {
        const video = document.createElement("video");
        video.src = src;
        video.controls = true;
        video.autoplay = true;
        video.loop = true;
        video.playsInline = true;
        stage.appendChild(video);
      } else {
        const img = document.createElement("img");
        img.src = src;
        img.alt = "Visual documentation";
        stage.appendChild(img);
      }

      lastFocused = document.activeElement as HTMLElement;
      lightbox.hidden = false;
      requestAnimationFrame(() => lightbox.classList.add("is-open"));
      document.body.style.overflow = "hidden";
      (closeBtn as HTMLElement).focus();
    }

    function closeMedia() {
      if (!lightbox || !stage) return;
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
      window.setTimeout(() => {
        lightbox.hidden = true;
        stage.innerHTML = ""; // stops/unloads the playing video
      }, 300);
      if (lastFocused && typeof lastFocused.focus === "function") lastFocused.focus();
    }

    items.forEach((item) => {
      item.addEventListener("click", () => {
        openMedia(item.dataset.mediaSrc || "", item.dataset.mediaType || "image");
      });
    });

    closeBtn.addEventListener("click", closeMedia);
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) closeMedia();
    });
  }

  // Global Escape-to-close, bound once. Looks up the current lightbox live so it
  // keeps working across view-transition page swaps.
  if (!(window as any).__galleryEscBound) {
    (window as any).__galleryEscBound = true;
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      const lb = document.getElementById("media-lightbox");
      if (lb && !lb.hidden) document.getElementById("lightbox-close")?.click();
    });
  }

  function init() {
    initTerminal();
    initLiveEdit();
    initGallery();
  }

  init();
  document.addEventListener("astro:after-swap", init);
</script>

<style>
  /* ============ HERO ============ */
  .immersive-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 5rem;
    background: var(--color-bg);
    overflow: hidden;
  }
  .hero-video-wrapper {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .hero-video-wrapper video,
  .hero-video-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
    filter: grayscale(1) contrast(1.05);
  }
  .hero-tint {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(to bottom, rgba(10, 10, 10, 0.5) 0%, transparent 30%, var(--color-bg) 97%),
      linear-gradient(to right, rgba(10, 10, 10, 0.6) 0%, transparent 55%);
  }
  .hero-watermark {
    position: absolute;
    top: 14vh;
    right: -1vw;
    z-index: 2;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(3.5rem, 11vw, 10rem);
    line-height: 0.8;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: var(--color-text);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
  }
  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
  }
  .hero-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    margin-bottom: 1.4rem;
  }
  .hero-eyebrow-row span {
    font-size: inherit;
    letter-spacing: inherit;
  }
  .he-cat {
    color: var(--color-accent);
    font-weight: 700;
