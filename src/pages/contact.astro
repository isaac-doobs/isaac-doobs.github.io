---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact — Cristian Dubineanschi"
  description="Get in touch with Cristian Dubineanschi — available for selected new-media, installation, and visual design work."
>
  <div class="contact-container container" id="contact-main-container">
    <!-- Page Header -->
    <section class="contact-header" id="contact-title-sec">
      <div class="header-line" id="contact-line-div"></div>
      <span class="system-code">Available for selected work — UTC+2</span>
      <h1 class="page-title cursor" id="contact-page-title">Contact</h1>
    </section>

    <!-- Two Column Data Grid -->
    <div class="contact-grid" id="contact-grid-content">
      <!-- Left Column: Editorial Contact Form -->
      <div class="contact-left" id="contact-form-column">
        <h2 class="section-title">01. Send a message</h2>
        <form class="editorial-form" id="signal-form">
          <div class="form-field">
            <label for="sender-name" class="font-mono">Name</label>
            <input
              type="text"
              id="sender-name"
              name="name"
              required
              placeholder="Your name"
              class="form-input"
            />
          </div>

          <div class="form-field">
            <label for="sender-email" class="font-mono">Email</label>
            <input
              type="email"
              id="sender-email"
              name="email"
              required
              placeholder="you@example.com"
              class="form-input"
            />
          </div>

          <div class="form-field">
            <label for="sender-message" class="font-mono">Message</label>
            <textarea
              id="sender-message"
              name="message"
              rows="6"
              required
              placeholder="Tell me about your project or exhibition proposal…"
              class="form-textarea"></textarea>
          </div>

          <!-- Honeypot: hidden from people; bots that fill it are dropped. -->
          <input
            type="text"
            name="botcheck"
            id="botcheck"
            class="hp-field"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <button type="submit" class="submit-btn" id="form-submit-btn">
            <span>Send message</span>
          </button>
        </form>
        <div
          id="form-status-log"
          class="form-status-msg font-mono"
          style="display: none;"
          role="status"
          aria-live="polite"
        >
        </div>
      </div>

      <!-- Right Column: Details -->
      <div class="contact-right" id="contact-channels-column">
        <h2 class="section-title">02. Details</h2>

        <div class="technical-parameters" id="contact-params-table">
          <h3 class="subsection-title">Reach me at</h3>
          <div class="param-row">
            <span class="param-name">Email</span>
            <span class="param-val">
              <a href="mailto:christian.doobi@gmail.com" class="tech-link"
                >christian.doobi@gmail.com</a
              >
            </span>
          </div>
          <div class="param-row">
            <span class="param-name">Location</span>
            <span class="param-val">Cluj-Napoca, RO · Chișinău, MD</span>
          </div>
          <div class="param-row">
            <span class="param-name">Timezone</span>
            <span class="param-val">UTC+2 — Eastern Europe</span>
          </div>
        </div>

        <div class="contact-notice reveal">
          <p class="notice-text">
            Available for selected new-media commissions, interactive light/sound installations, and
            visual system consulting. Typically responds within 48 hours.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Web3Forms delivers the submission to your inbox without a backend. Get a
  // free access key at https://web3forms.com (enter your email — it's sent to
  // you instantly) and paste it below. The key is public/client-side by design;
  // spam is filtered by the honeypot field and Web3Forms' own checks.
  const ACCESS_KEY = "c8d52298-8513-4f59-b149-3b83927c8d8f";
  const ENDPOINT = "https://api.web3forms.com/submit";
  const CONTACT_EMAIL = "christian.doobi@gmail.com";

  type StatusLine = { text: string; kind?: "info" | "success" | "error" };

  function setupFormSubmit() {
    const form = document.getElementById("signal-form") as HTMLFormElement | null;
    const statusLog = document.getElementById("form-status-log");
    const submitBtn = document.getElementById("form-submit-btn") as HTMLButtonElement | null;
    if (!form || !statusLog || !submitBtn) return;

    const btnLabel = submitBtn.querySelector("span");

    const setStatus = (lines: StatusLine[]) => {
      statusLog.innerHTML = lines
        .map((l) => `<div class="status-line ${l.kind ?? "info"}">${l.text}</div>`)
        .join("");
      statusLog.style.display = "flex";
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const data = new FormData(form);

      // Honeypot tripped → almost certainly a bot. Feign success, send nothing.
      if (String(data.get("botcheck") || "").length > 0) {
        setStatus([{ text: "Message sent. Thanks — I'll be in touch.", kind: "success" }]);
        form.reset();
        return;
      }

      const name = String(data.get("name") || "").trim();
      const email = String(data.get("email") || "").trim();
      const message = String(data.get("message") || "").trim();

      submitBtn.disabled = true;
      if (btnLabel) btnLabel.textContent = "Sending…";
      setStatus([{ text: "Transmitting message…", kind: "info" }]);

      try {
        const res = await fetch(ENDPOINT, {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify({
            access_key: ACCESS_KEY,
            name,
            email,
            message,
            subject: `Portfolio enquiry — ${name || "no name"}`,
            from_name: "Portfolio contact form",
          }),
        });
        const result = await res.json();

        if (res.ok && result.success) {
          setStatus([
            { text: "Message sent.", kind: "success" },
            { text: "Thanks — I'll reply within ~48 hours.", kind: "info" },
          ]);
          form.reset();
        } else {
          setStatus([
            { text: "Couldn't send — please try again.", kind: "error" },
            { text: `Or email me directly: ${CONTACT_EMAIL}`, kind: "info" },
          ]);
        }
      } catch {
        setStatus([
          { text: "Network error — message not sent.", kind: "error" },
          { text: `Email me directly: ${CONTACT_EMAIL}`, kind: "info" },
        ]);
      } finally {
        submitBtn.disabled = false;
        if (btnLabel) btnLabel.textContent = "Send message";
      }
    });
  }

  setupFormSubmit();
  document.addEventListener("astro:after-swap", setupFormSubmit);
</script>

<style>
  .contact-container {
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  /* Page Header */
  .contact-header {
    margin-bottom: 3rem;
  }
  .header-line {
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
    margin-bottom: 1.5rem;
  }
  .system-code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-accent);
    letter-spacing: 0.08em;
  }
  .page-title {
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 400;
    margin-top: 0.5rem;
    letter-spacing: -0.03em;
    line-height: 1;
    text-transform: uppercase;
  }

  /* Layout Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
  }

  .section-title {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.75rem;
    margin-bottom: 2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Editorial Form styling */
  .editorial-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-field label {
    font-size: 0.72rem;
    color: var(--color-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .form-input,
  .form-textarea {
    background-color: transparent;
    border: none;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.5rem 0;
    font-size: 0.9rem;
    outline: none;
    border-radius: 0;
    transition: border-color 0.3s var(--ease-out-expo);
  }
  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--color-muted);
    opacity: 0.35;
  }
  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--color-accent);
  }
  .submit-btn {
    align-self: flex-start;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.8rem 2rem;
    border-radius: 0;
    cursor: pointer;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.3s var(--ease-out-expo);
    margin-top: 1rem;
  }
  .submit-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background-color: var(--color-accent-dark);
  }
  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    border-color: var(--color-border);
    color: var(--color-muted);
  }

  /* Inline status messages */
  .form-status-msg {
    margin-top: 1.5rem;
    font-size: 0.76rem;
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .form-status-msg :global(.status-line) {
    padding: 0.5rem 0;
  }
  .form-status-msg :global(.status-line.info) {
    color: var(--color-muted);
  }
  .form-status-msg :global(.status-line.success) {
    color: var(--color-accent);
    font-weight: 700;
  }
  .form-status-msg :global(.status-line.error) {
    color: var(--color-error);
    font-weight: 700;
  }

  /* Honeypot hidden from layout flow */
  .hp-field {
    display: none;
  }

  /* Right Column Details */
  .technical-parameters {
    border: 1px solid var(--color-border);
    background-color: var(--color-card-bg);
    padding: 2rem;
    border-radius: 0;
    margin-bottom: 2rem;
    transition:
      background-color 0.4s ease,
      border-color 0.4s ease;
  }
  .subsection-title {
    font-family: var(--font-sans);
    font-size: 0.76rem;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .param-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .param-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .param-name {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--color-muted);
    font-weight: 500;
  }
  .param-val {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--color-text);
    text-align: right;
  }
  .tech-link {
    color: var(--color-accent);
    font-weight: 600;
  }
  .tech-link:hover {
    text-decoration: underline;
  }

  .contact-notice {
    padding: 1.5rem;
    border-left: 2px solid var(--color-accent);
    background-color: var(--color-bg-soft);
  }
  .notice-text {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-muted);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }
  @media (max-width: 768px) {
    .contact-container {
      padding-top: 1.5rem;
    }
  }
</style>
