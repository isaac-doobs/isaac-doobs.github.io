---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact — Cristian Dubineanschi"
  description="Get in touch with Cristian Dubineanschi — available for selected new-media, installation, and visual design work."
>
  <div class="contact-container container" id="contact-main-container">
    <!-- Page Header -->
    <section class="contact-header" id="contact-title-sec">
      <div class="header-line" id="contact-line-div"></div>
      <span class="system-code">Available for selected work — UTC+2</span>
      <h1 class="page-title cursor" id="contact-page-title">Contact</h1>
    </section>

    <!-- Two Column Data Grid -->
    <div class="contact-grid" id="contact-grid-content">
      <!-- Left Column: Interactive Signal Terminal Form -->
      <div class="contact-left" id="contact-form-column">
        <h2 class="section-title">01. Send a message</h2>
        <div class="terminal-form-box glow-border">
          <div class="terminal-form-header">
            <span class="form-dot red"></span>
            <span class="form-dot yellow"></span>
            <span class="form-dot green"></span>
            <span class="form-title">new-message</span>
          </div>
          <form class="terminal-form" id="signal-form">
            <div class="form-field">
              <label for="sender-name" class="font-mono">Name</label>
              <input
                type="text"
                id="sender-name"
                name="name"
                required
                placeholder="Your name"
                class="form-input font-mono"
              />
            </div>

            <div class="form-field">
              <label for="sender-email" class="font-mono">Email</label>
              <input
                type="email"
                id="sender-email"
                name="email"
                required
                placeholder="you@example.com"
                class="form-input font-mono"
              />
            </div>

            <div class="form-field">
              <label for="sender-message" class="font-mono">Message</label>
              <textarea
                id="sender-message"
                name="message"
                rows="6"
                required
                placeholder="Tell me about your project…"
                class="form-textarea font-mono"></textarea>
            </div>

            <!-- Honeypot: hidden from people; bots that fill it are dropped. -->
            <input
              type="text"
              name="botcheck"
              id="botcheck"
              class="hp-field"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />

            <button type="submit" class="submit-btn font-mono" id="form-submit-btn">
              <span>Send message</span>
            </button>
          </form>
          <div
            id="form-status-log"
            class="form-status-log font-mono"
            style="display: none;"
            role="status"
            aria-live="polite"
          >
          </div>
        </div>
      </div>

      <!-- Right Column: System Comm Channels & Terminal Outputs -->
      <div class="contact-right" id="contact-channels-column">
        <h2 class="section-title">02. Details</h2>

        <div class="technical-parameters" id="contact-params-table">
          <h3 class="subsection-title">Reach me at</h3>
          <div class="param-row">
            <span class="param-name">Email</span>
            <span class="param-val">
              <a href="mailto:christian.doobi@gmail.com" class="tech-link"
                >christian.doobi@gmail.com</a
              >
            </span>
          </div>
          <div class="param-row">
            <span class="param-name">Location</span>
            <span class="param-val">Cluj-Napoca, RO</span>
          </div>
          <div class="param-row">
            <span class="param-name">Timezone</span>
            <span class="param-val">UTC+2 — Eastern Europe</span>
          </div>
        </div>

        <div class="code-terminal" id="contact-diag-term">
          <div class="terminal-header">
            <div class="terminal-buttons">
              <span class="terminal-dot red"></span>
              <span class="terminal-dot yellow"></span>
              <span class="terminal-dot green"></span>
            </div>
            <span class="terminal-title">status</span>
          </div>
          <div class="terminal-body font-mono text-glow">
            <div class="diag-line">Available for selected work</div>
            <div class="diag-line">Replies within ~48 hours</div>
            <div class="diag-line">Based in Cluj-Napoca, RO (UTC+2)</div>
            <div class="diag-line">Email open</div>
            <div class="diag-line blink-cursor">▋</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Web3Forms delivers the submission to your inbox without a backend. Get a
  // free access key at https://web3forms.com (enter your email — it's sent to
  // you instantly) and paste it below. The key is public/client-side by design;
  // spam is filtered by the honeypot field and Web3Forms' own checks.
  const ACCESS_KEY = "c8d52298-8513-4f59-b149-3b83927c8d8f";
  const ENDPOINT = "https://api.web3forms.com/submit";
  const CONTACT_EMAIL = "christian.doobi@gmail.com";

  type StatusLine = { text: string; kind?: "info" | "success" | "error" };

  function setupFormSubmit() {
    const form = document.getElementById("signal-form") as HTMLFormElement | null;
    const statusLog = document.getElementById("form-status-log");
    const submitBtn = document.getElementById("form-submit-btn") as HTMLButtonElement | null;
    if (!form || !statusLog || !submitBtn) return;

    const btnLabel = submitBtn.querySelector("span");

    const setStatus = (lines: StatusLine[]) => {
      statusLog.innerHTML = lines
        .map((l) => `<div class="status-line ${l.kind ?? "info"}">${l.text}</div>`)
        .join("");
      statusLog.style.display = "flex";
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const data = new FormData(form);

      // Honeypot tripped → almost certainly a bot. Feign success, send nothing.
      if (String(data.get("botcheck") || "").length > 0) {
        setStatus([{ text: "Message sent. Thanks — I'll be in touch.", kind: "success" }]);
        form.reset();
        return;
      }

      const name = String(data.get("name") || "").trim();
      const email = String(data.get("email") || "").trim();
      const message = String(data.get("message") || "").trim();

      submitBtn.disabled = true;
      if (btnLabel) btnLabel.textContent = "Sending…";
      setStatus([{ text: "Transmitting message…", kind: "info" }]);

      try {
        const res = await fetch(ENDPOINT, {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify({
            access_key: ACCESS_KEY,
            name,
            email,
            message,
            subject: `Portfolio enquiry — ${name || "no name"}`,
            from_name: "Portfolio contact form",
          }),
        });
        const result = await res.json();

        if (res.ok && result.success) {
          setStatus([
            { text: "Message sent.", kind: "success" },
            { text: "Thanks — I'll reply within ~48 hours.", kind: "info" },
          ]);
          form.reset();
        } else {
          setStatus([
            { text: "Couldn't send — please try again.", kind: "error" },
            { text: `Or email me directly: ${CONTACT_EMAIL}`, kind: "info" },
          ]);
        }
      } catch {
        setStatus([
          { text: "Network error — message not sent.", kind: "error" },
          { text: `Email me directly: ${CONTACT_EMAIL}`, kind: "info" },
        ]);
      } finally {
        submitBtn.disabled = false;
        if (btnLabel) btnLabel.textContent = "Send message";
      }
    });
  }

  setupFormSubmit();
  document.addEventListener("astro:after-swap", setupFormSubmit);
</script>

<style>
  .contact-container {
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  /* Page Header */
  .contact-header {
    margin-bottom: 3rem;
  }
  .header-line {
    height: 2px;
    background: linear-gradient(to right, var(--color-accent), transparent);
    margin-bottom: 1rem;
  }
  .system-code {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }
  .page-title {
    font-size: clamp(1.9rem, 4vw, 3rem);
    font-weight: 400;
    margin-top: 0.5rem;
    letter-spacing: -0.03em;
    line-height: 1;
    text-transform: none;
  }

  /* Layout Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.25fr 1.1fr;
    gap: 4rem;
  }

  .section-title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.75rem;
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }

  /* Terminal Form styling */
  .terminal-form-box {
    border: 1px solid var(--color-terminal-border);
    background-color: var(--color-terminal-bg);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }
  .terminal-form-box:hover {
    border-color: rgba(139, 111, 196, 0.3);
  }
  .terminal-form-header {
    background-color: var(--color-terminal-hdr);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid var(--color-terminal-border);
  }
  .form-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-terminal-border);
  }
  .form-dot.red {
    background-color: #ef4444;
  }
  .form-dot.yellow {
    background-color: #eab308;
  }
  .form-dot.green {
    background-color: #22c55e;
  }
  .form-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-terminal-muted);
    margin-left: 8px;
    letter-spacing: 0.05em;
  }
  .terminal-form {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form-field label {
    font-size: 0.76rem;
    color: var(--color-terminal-accent);
    letter-spacing: 0.05em;
  }
  .form-input,
  .form-textarea {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-terminal-border);
    color: var(--color-terminal-text);
    padding: 0.75rem;
    border-radius: 4px;
    font-size: 0.82rem;
    outline: none;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--color-terminal-muted);
    opacity: 0.5;
  }
  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--color-terminal-accent);
    box-shadow: 0 0 10px rgba(139, 111, 196, 0.15);
  }
  .submit-btn {
    background: none;
    border: 1px solid var(--color-terminal-accent);
    color: var(--color-terminal-accent);
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 0.5rem;
  }
  .submit-btn:hover {
    background-color: var(--color-terminal-accent);
    color: #000000;
    border-color: var(--color-terminal-accent);
    box-shadow: 0 0 15px rgba(139, 111, 196, 0.35);
  }
  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    border-color: var(--color-terminal-border);
    color: var(--color-terminal-muted);
  }

  /* Status log */
  .form-status-log {
    padding: 0 1.5rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .status-line {
    font-size: 0.76rem;
    line-height: 1.4;
  }
  .status-line.info {
    color: var(--color-terminal-muted);
  }
  .status-line.success {
    color: var(--color-terminal-success);
    font-weight: 700;
  }
  .status-line.error {
    color: #f87171;
    font-weight: 700;
  }

  /* Honeypot — visually and from-flow hidden, but present for bots to fill. */
  .hp-field {
    display: none;
  }

  /* Right Column details */
  .technical-parameters {
    border: 1px solid var(--color-border);
    background-color: var(--color-card-bg);
    padding: 1.5rem;
    border-radius: 4px;
    margin-bottom: 2rem;
    transition:
      background-color 0.4s ease,
      border-color 0.4s ease;
  }
  .subsection-title {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-accent);
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }
  .param-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .param-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .param-name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-muted);
    font-weight: 500;
  }
  .param-val {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-text);
    text-align: right;
  }
  .tech-link {
    color: var(--color-accent);
    font-weight: 600;
  }
  .tech-link:hover {
    text-decoration: underline;
    text-shadow: var(--color-nav-glow);
  }
  .pgp-key {
    letter-spacing: 0.05em;
    font-size: 0.72rem;
    color: var(--color-muted-lavender);
  }

  .diag-line {
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--color-terminal-text);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
  @media (max-width: 768px) {
    .contact-container {
      padding-top: 1.5rem;
    }
  }

  /* Light theme — the message form and status box are decorative "terminals",
     not code, so adapt them to the light palette instead of staying dark.
     (Dark theme keeps the original terminal look untouched.) */
  :root[data-theme="light"] .terminal-form-box,
  :root[data-theme="light"] #contact-diag-term {
    background-color: var(--color-card-bg);
    border-color: var(--color-border);
  }
  :root[data-theme="light"] .terminal-form-box:hover {
    border-color: rgba(95, 74, 147, 0.35);
  }
  :root[data-theme="light"] .terminal-form-header,
  :root[data-theme="light"] #contact-diag-term .terminal-header {
    background-color: var(--color-bg-soft);
    border-bottom-color: var(--color-border);
  }
  :root[data-theme="light"] .form-title,
  :root[data-theme="light"] #contact-diag-term .terminal-title {
    color: var(--color-muted);
  }
  :root[data-theme="light"] .form-field label {
    color: var(--color-accent);
  }
  :root[data-theme="light"] .form-input,
  :root[data-theme="light"] .form-textarea {
    background-color: rgba(20, 19, 15, 0.03);
    border-color: var(--color-border);
    color: var(--color-text);
  }
  :root[data-theme="light"] .form-input::placeholder,
  :root[data-theme="light"] .form-textarea::placeholder {
    color: var(--color-muted);
  }
  :root[data-theme="light"] .form-input:focus,
  :root[data-theme="light"] .form-textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 10px rgba(95, 74, 147, 0.15);
  }
  :root[data-theme="light"] .submit-btn {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  :root[data-theme="light"] .submit-btn:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }
  :root[data-theme="light"] .status-line.info {
    color: var(--color-muted);
  }
  :root[data-theme="light"] .status-line.success {
    color: var(--color-accent);
  }
  :root[data-theme="light"] .status-line.error {
    color: #c0392b;
  }
  :root[data-theme="light"] #contact-diag-term .terminal-body {
    background-color: var(--color-card-bg);
  }
  :root[data-theme="light"] #contact-diag-term .diag-line,
  :root[data-theme="light"] #contact-diag-term .blink-cursor {
    color: var(--color-text);
  }
</style>
