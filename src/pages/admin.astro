---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

// Authoring console — localhost-only. It talks to the local CMS daemon and must
// never ship on the deployed site, so redirect to home in production builds.
if (import.meta.env.PROD) return Astro.redirect("/");

// Load projects at build time to serve as fallback/static data
const initialProjects = await getCollection("projects");
initialProjects.sort((a, b) => b.data.year - a.data.year);

// We serialize the initial projects to pass to our client-side script
const serializedProjects = initialProjects.map((p) => ({
  id: p.id,
  data: p.data,
  body: p.body || "",
}));
---

<Layout
  title="SYS // CONTROL - Local System Controller"
  description="System management dashboard for local file writing and project editing."
>
  <div class="admin-container container" id="admin-main-container">
    <!-- Header status -->
    <section class="admin-header" id="admin-head-sec">
      <div class="header-line" id="admin-div-line"></div>
      <div class="header-status-strip">
        <span class="system-code">[SYS_DAEMON: ADMIN_CONTROL_PANEL]</span>
        <div class="daemon-indicator" id="daemon-indicator-light">
          <span class="indicator-dot yellow" id="indicator-dot"></span>
          <span class="indicator-text font-mono" id="indicator-text"
            >CONNECTING TO LOCAL DAEMON...</span
          >
        </div>
      </div>
      <h1 class="page-title cursor" id="admin-title">SYSTEM CONTROLLER</h1>
    </section>

    <!-- Access Denied Shield (Shown via client JS on public domains) -->
    <div id="admin-auth-shield" class="auth-shield hidden">
      <div class="auth-box font-mono">
        <span class="text-red warning-glow">[ACCESS_DENIED // PORT_SECURED]</span>
        <h2 class="auth-title">CORE CONTROL PORTAL REJECTED</h2>
        <p class="auth-desc">
          THE ACTIVE REPOSITORY SYSTEM TERMINAL CAN ONLY BE ACCESSED VIA DIRECT CONNECTION TO THE
          LOCALHOST DAEMON ON YOUR DEVELOPMENT MACHINE.
        </p>
        <a href="/" class="auth-back-link font-mono">[00] RETURN TO TERMINAL</a>
      </div>
    </div>

    <!-- Admin Work Grid -->
    <div class="admin-grid" id="admin-dashboard-grid">
      <!-- Left Panel: Project Select List -->
      <div class="admin-panel left-panel" id="project-list-panel">
        <div class="panel-header">
          <span class="panel-num">[01]</span>
          <h2 class="panel-title">PROJECT REGISTER</h2>
        </div>

        <div class="list-controls">
          <button class="action-btn font-mono" id="create-new-node-btn" disabled>
            [+] CREATE NEW PROJECT NODE
          </button>
        </div>

        <div class="project-nodes-list" id="nodes-list-container">
          <!-- Populated by JS -->
          <div class="loading-placeholder font-mono">Loading archive registry...</div>
        </div>

        <!-- Terminal log outputs -->
        <div class="terminal-log-box" id="system-logs-box">
          <div class="log-box-header font-mono">
            <span>CONSOLE_LOGS</span>
            <span class="blink-cursor">_</span>
          </div>
          <div class="log-lines font-mono" id="console-log-lines">
            <p class="log-entry text-muted">>>> Initializing terminal debugger...</p>
            <p class="log-entry">>>> Reading static build fallback assets...</p>
            <p class="log-entry text-green">
              >>> Loaded {serializedProjects.length} projects from static context.
            </p>
          </div>
        </div>
      </div>

      <!-- Right Panel: Edit Form -->
      <div class="admin-panel right-panel" id="project-form-panel">
        <div class="panel-header">
          <span class="panel-num">[02]</span>
          <h2 class="panel-title" id="form-header-title">NODE PARAMETERS</h2>
        </div>

        <div class="empty-form-message font-mono" id="empty-form-msg">
          SELECT A PROJECT NODE FROM THE REGISTER TO ACCESS FILE EDIT MODE.
        </div>

        <!-- Editing form, hidden until a project is selected -->
        <form class="edit-node-form hidden" id="project-edit-form">
          <input type="hidden" id="field-id" />

          <div class="form-row-grid">
            <div class="input-group">
              <label for="field-title">TITLE</label>
              <input type="text" id="field-title" required />
            </div>

            <div class="input-group">
              <label for="field-year">YEAR</label>
              <input type="number" id="field-year" required />
            </div>
          </div>

          <div class="form-row-grid three-cols">
            <div class="input-group">
              <label for="field-category">CATEGORY</label>
              <select id="field-category">
                <option value="Interactive">Interactive</option>
                <option value="Design">Design</option>
              </select>
            </div>

            <div class="input-group">
              <label for="field-status">STATUS</label>
              <select id="field-status">
                <option value="Operational">Operational</option>
                <option value="Active">Active</option>
                <option value="Archived">Archived</option>
                <option value="In Development">In Development</option>
              </select>
            </div>

            <div class="input-group">
              <label for="field-medium">MEDIUM TAGS (Comma separated)</label>
              <input type="text" id="field-medium" required />
            </div>
          </div>

          <div class="input-group">
            <label for="field-concept">ARTISTIC CONCEPT STATEMENT (150–300 words)</label>
            <textarea id="field-concept" rows="4" required></textarea>
          </div>

          <div class="input-group">
            <label for="field-academic-context">ACADEMIC / ARTISTIC CONTEXT</label>
            <textarea id="field-academic-context" rows="3"></textarea>
          </div>

          <div class="form-row-grid">
            <div class="input-group">
              <label for="field-process">PROCESS — ONE STEP PER LINE</label>
              <textarea id="field-process" rows="4" placeholder="Step one
Step two
Step three"
              ></textarea>
            </div>
            <div class="input-group">
              <label for="field-challenges">CHALLENGES &amp; SOLUTIONS</label>
              <textarea id="field-challenges" rows="4"></textarea>
            </div>
          </div>

          <div class="input-group">
            <label for="field-research-relevance">RESEARCH RELEVANCE (dissertation theme)</label>
            <textarea id="field-research-relevance" rows="3"></textarea>
          </div>

          <div class="input-group">
            <label for="field-media-gallery">VISUAL DOCUMENTATION (comma-separated URLs)</label>
            <input type="text" id="field-media-gallery" placeholder="https://..., https://..." />
          </div>

          <div class="form-row-grid three-cols">
            <div class="input-group">
              <label for="field-software">SOFTWARE STACK (Comma separated)</label>
              <input type="text" id="field-software" required />
            </div>
            <div class="input-group">
              <label for="field-hardware">HARDWARE CONFIG (Comma separated)</label>
              <input type="text" id="field-hardware" required />
            </div>
            <div class="input-group">
              <label for="field-inputs">INPUT VECTORS (Comma separated)</label>
              <input type="text" id="field-inputs" required />
            </div>
          </div>

          <div class="form-row-grid">
            <div class="input-group">
              <label for="field-video">HERO VIDEO STREAM URL (External)</label>
              <input type="text" id="field-video" required />
            </div>
            <div class="input-group">
              <label for="field-thumbnail">GRID THUMBNAIL VIDEO URL</label>
              <input type="text" id="field-thumbnail" required />
            </div>
          </div>

          <div class="form-row-grid">
            <div class="input-group">
              <label for="field-blueprint">BLUEPRINT SCHEMATIC IMAGE PATH</label>
              <input type="text" id="field-blueprint" placeholder="/assets/custom_blueprint.png" />
            </div>
            <div class="input-group">
              <label for="field-blueprint-caption">BLUEPRINT CAPTION</label>
              <input type="text" id="field-blueprint-caption" />
            </div>
          </div>

          <div class="form-row-grid">
            <div class="input-group size-small">
              <label for="field-code-language">CODE LANGUAGE</label>
              <input type="text" id="field-code-language" required />
            </div>
          </div>

          <div class="input-group">
            <label for="field-code-snippet">ALGORITHM SNIPPET</label>
            <textarea id="field-code-snippet" rows="8" class="font-mono"></textarea>
          </div>

          <div class="input-group">
            <label for="field-body">DETAILED MARKDOWN CONTENT (Renders under concept)</label>
            <textarea id="field-body" rows="4" class="font-mono"></textarea>
          </div>

          <!-- Dynamic YAML Frontmatter Live Preview -->
          <div class="yaml-live-preview">
            <div class="preview-header font-mono">YAML_METADATA_PREVIEW</div>
            <pre class="preview-body font-mono" id="yaml-preview-box">Updating preview...</pre>
          </div>

          <div class="form-actions">
            <button type="submit" class="apply-btn font-mono" id="apply-btn" disabled>
              [SUBMIT] APPLY RUNTIME CHANGES TO DISK
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<!-- Client Script to communicate with scripts/cms-server.js -->
<script define:vars={{ serializedProjects }}>
  // Verify Hostname Shield (localhost/127.0.0.1 only)
  if (window.location.hostname !== "localhost" && window.location.hostname !== "127.0.0.1") {
    const shield = document.getElementById("admin-auth-shield");
    const grid = document.getElementById("admin-dashboard-grid");
    const header = document.getElementById("admin-head-sec");
    if (shield) shield.classList.remove("hidden");
    if (grid) grid.classList.add("hidden");
    if (header) header.style.display = "none";
  }

  const CMS_API = "http://localhost:4322/api";
  let projects = [...serializedProjects];
  let selectedProject = null;
  let isDaemonConnected = false;

  // Cache DOM
  const listContainer = document.getElementById("nodes-list-container");
  const emptyFormMsg = document.getElementById("empty-form-msg");
  const editForm = document.getElementById("project-edit-form");
  const applyBtn = document.getElementById("apply-btn");
  const createNewBtn = document.getElementById("create-new-node-btn");
  const dot = document.getElementById("indicator-dot");
  const indicatorText = document.getElementById("indicator-text");
  const consoleLog = document.getElementById("console-log-lines");
  const yamlPreviewBox = document.getElementById("yaml-preview-box");

  // Fields
  const fId = document.getElementById("field-id");
  const fTitle = document.getElementById("field-title");
  const fYear = document.getElementById("field-year");
  const fCategory = document.getElementById("field-category");
  const fStatus = document.getElementById("field-status");
  const fMedium = document.getElementById("field-medium");
  const fConcept = document.getElementById("field-concept");
  const fAcademicContext = document.getElementById("field-academic-context");
  const fProcess = document.getElementById("field-process");
  const fChallenges = document.getElementById("field-challenges");
  const fResearchRelevance = document.getElementById("field-research-relevance");
  const fMediaGallery = document.getElementById("field-media-gallery");
  const fSoftware = document.getElementById("field-software");
  const fHardware = document.getElementById("field-hardware");
  const fInputs = document.getElementById("field-inputs");
  const fVideo = document.getElementById("field-video");
  const fThumbnail = document.getElementById("field-thumbnail");
  const fBlueprint = document.getElementById("field-blueprint");
  const fBlueprintCaption = document.getElementById("field-blueprint-caption");
  const fCodeLang = document.getElementById("field-code-language");
  const fCodeSnippet = document.getElementById("field-code-snippet");
  const fBody = document.getElementById("field-body");

  function addLog(message, type = "normal") {
    if (!consoleLog) return;
    const p = document.createElement("p");
    p.classList.add("log-entry");
    if (type === "green") p.classList.add("text-green");
    if (type === "purple") p.classList.add("text-purple");
    if (type === "red") p.classList.add("text-red");
    if (type === "muted") p.classList.add("text-muted");
    p.textContent = `>>> ${message}`;
    consoleLog.appendChild(p);
    consoleLog.scrollTop = consoleLog.scrollHeight;
  }

  // Ping the local CMS daemon to check connection
  async function checkDaemonConnection() {
    try {
      addLog("Connecting to system daemon on port 4322...", "muted");
      const res = await fetch(`${CMS_API}/projects`, { method: "GET" });
      if (res.ok) {
        // Connected! Overwrite build projects with live database projects
        projects = await res.json();
        isDaemonConnected = true;

        dot.className = "indicator-dot green";
        indicatorText.textContent = "DAEMON CONNECTED [READ-WRITE DIRECTORIES]";
        createNewBtn.removeAttribute("disabled");
        applyBtn.removeAttribute("disabled");

        addLog("Local daemon connection established.", "green");
        addLog(`System unlocked. Sync completed: ${projects.length} nodes loaded.`, "green");
      } else {
        throw new Error("Connection refused");
      }
    } catch (err) {
      isDaemonConnected = false;
      dot.className = "indicator-dot red";
      indicatorText.textContent = "STATIC ARCHIVE MODE [READ-ONLY FILE SYSTEM]";
      createNewBtn.setAttribute("disabled", "true");
      applyBtn.setAttribute("disabled", "true");

      addLog("Connection refused. System daemon offline.", "red");
      addLog("Operational environment: Read-Only. Live writes disabled.", "purple");
    }
    renderNodesList();
  }

  function renderNodesList() {
    if (!listContainer) return;
    listContainer.innerHTML = "";

    if (projects.length === 0) {
      listContainer.innerHTML = '<div class="empty font-mono">No nodes registered.</div>';
      return;
    }

    projects.forEach((project) => {
      const button = document.createElement("button");
      button.className = `node-item font-mono ${selectedProject && selectedProject.id === project.id ? "active" : ""}`;
      button.innerHTML = `
        <span class="node-bullet">↳</span>
        <div class="node-details">
          <span class="node-name">${project.data.title}</span>
          <span class="node-tag">${project.data.status} // ${project.data.year}</span>
        </div>
      `;
      button.addEventListener("click", () => selectProject(project));
      listContainer.appendChild(button);
    });
  }

  function selectProject(project) {
    selectedProject = project;
    renderNodesList();

    emptyFormMsg.classList.add("hidden");
    editForm.classList.remove("hidden");

    // Fill values
    fId.value = project.id;
    fTitle.value = project.data.title;
    fYear.value = project.data.year;
    fCategory.value = project.data.category || "Interactive";
    fStatus.value = project.data.status;
    fMedium.value = project.data.medium.join(", ");
    fConcept.value = project.data.concept;
    fAcademicContext.value = project.data.academicContext || "";
    fProcess.value = Array.isArray(project.data.process)
      ? project.data.process.join("\n")
      : project.data.process || "";
    fChallenges.value = project.data.challenges || "";
    fResearchRelevance.value = project.data.researchRelevance || "";
    fMediaGallery.value = (project.data.mediaGallery || []).join(", ");
    fSoftware.value = project.data.software.join(", ");
    fHardware.value = project.data.hardware.join(", ");
    fInputs.value = project.data.inputs.join(", ");
    fVideo.value = project.data.videoUrl;
    fThumbnail.value = project.data.thumbnailUrl;
    fBlueprint.value = project.data.blueprintUrl || "";
    fBlueprintCaption.value = project.data.blueprintCaption || "";
    fCodeLang.value = project.data.codeLanguage || "glsl";
    fCodeSnippet.value = project.data.codeSnippet || "";
    fBody.value = project.body || "";

    addLog(`Opened node: ${project.id}.md for examination.`, "purple");
    updateLivePreview();
  }

  // Parse comma separated strings into clean arrays
  function cleanArray(str) {
    return str
      .split(",")
      .map((s) => s.trim())
      .filter((s) => s !== "");
  }

  function getFormPayload() {
    return {
      id: fId.value,
      data: {
        title: fTitle.value,
        category: fCategory.value,
        year: Number(fYear.value),
        status: fStatus.value,
        medium: cleanArray(fMedium.value),
        concept: fConcept.value,
        academicContext: fAcademicContext.value,
        process: fProcess.value
          .split("\n")
          .map((s) => s.trim())
          .filter(Boolean),
        challenges: fChallenges.value,
        researchRelevance: fResearchRelevance.value,
        mediaGallery: cleanArray(fMediaGallery.value),
        software: cleanArray(fSoftware.value),
        hardware: cleanArray(fHardware.value),
        inputs: cleanArray(fInputs.value),
        videoUrl: fVideo.value,
        thumbnailUrl: fThumbnail.value,
        blueprintUrl: fBlueprint.value,
        blueprintCaption: fBlueprintCaption.value,
        codeLanguage: fCodeLang.value,
        codeSnippet: fCodeSnippet.value,
      },
      body: fBody.value,
    };
  }

  function updateLivePreview() {
    if (!yamlPreviewBox) return;
    const payload = getFormPayload();

    let yaml = "---\n";
    yaml += `title: "${payload.data.title}"\n`;
    yaml += `category: "${payload.data.category}"\n`;
    yaml += `year: ${payload.data.year}\n`;
    yaml += `status: "${payload.data.status}"\n`;
    yaml += `medium:\n${payload.data.medium.map((m) => `  - "${m}"`).join("\n")}\n`;
    yaml += `concept: "${payload.data.concept.replace(/"/g, '\\"')}"\n`;
    if (payload.data.academicContext)
      yaml += `academicContext: "${payload.data.academicContext.replace(/"/g, '\\"')}"\n`;
    if (payload.data.process && payload.data.process.length > 0) {
      yaml += `process:\n${payload.data.process.map((s) => `  - "${s.replace(/"/g, '\\"')}"`).join("\n")}\n`;
    }
    if (payload.data.challenges)
      yaml += `challenges: "${payload.data.challenges.replace(/"/g, '\\"')}"\n`;
    if (payload.data.researchRelevance)
      yaml += `researchRelevance: "${payload.data.researchRelevance.replace(/"/g, '\\"')}"\n`;
    if (payload.data.mediaGallery && payload.data.mediaGallery.length > 0) {
      yaml += `mediaGallery:\n${payload.data.mediaGallery.map((u) => `  - "${u}"`).join("\n")}\n`;
    }
    yaml += `software:\n${payload.data.software.map((s) => `  - "${s}"`).join("\n")}\n`;
    yaml += `hardware:\n${payload.data.hardware.map((h) => `  - "${h}"`).join("\n")}\n`;
    yaml += `inputs:\n${payload.data.inputs.map((i) => `  - "${i}"`).join("\n")}\n`;
    yaml += `videoUrl: "${payload.data.videoUrl}"\n`;
    yaml += `thumbnailUrl: "${payload.data.thumbnailUrl}"\n`;
    if (payload.data.blueprintUrl) yaml += `blueprintUrl: "${payload.data.blueprintUrl}"\n`;
    if (payload.data.blueprintCaption)
      yaml += `blueprintCaption: "${payload.data.blueprintCaption}"\n`;
    yaml += `codeLanguage: "${payload.data.codeLanguage}"\n`;
    if (payload.data.codeSnippet) {
      yaml += "codeSnippet: |\n";
      yaml +=
        payload.data.codeSnippet
          .split("\n")
          .map((l) => `  ${l}`)
          .join("\n") + "\n";
    }
    yaml += "---\n";
    yaml += payload.body;

    yamlPreviewBox.textContent = yaml;
  }

  // Update live preview on key inputs
  const formInputs = [
    fTitle,
    fYear,
    fCategory,
    fStatus,
    fMedium,
    fConcept,
    fAcademicContext,
    fProcess,
    fChallenges,
    fResearchRelevance,
    fMediaGallery,
    fSoftware,
    fHardware,
    fInputs,
    fVideo,
    fThumbnail,
    fBlueprint,
    fBlueprintCaption,
    fCodeLang,
    fCodeSnippet,
    fBody,
  ];
  formInputs.forEach((input) => {
    if (input) {
      input.addEventListener("input", updateLivePreview);
      input.addEventListener("change", updateLivePreview);
    }
  });

  // Handle Form Submission / Save
  if (editForm) {
    editForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!isDaemonConnected) {
        addLog("Action aborted: cannot write disk in read-only environment.", "red");
        return;
      }

      const payload = getFormPayload();
      addLog(`Sending packet update for ${payload.id}.md...`, "muted");

      try {
        const res = await fetch(`${CMS_API}/projects/save`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          addLog(`Success! ${payload.id}.md written back to disk.`, "green");
          // Update local memory state
          const idx = projects.findIndex((p) => p.id === payload.id);
          if (idx !== -1) {
            projects[idx] = payload;
          }
          renderNodesList();
        } else {
          const errData = await res.json();
          throw new Error(errData.error || "Failed to save");
        }
      } catch (err) {
        addLog(`Error writing file: ${err.message}`, "red");
      }
    });
  }

  // Handle Create New Project Node
  if (createNewBtn) {
    createNewBtn.addEventListener("click", async () => {
      if (!isDaemonConnected) return;

      const name = prompt("ENTER NEW PROJECT TITLE NAME:");
      if (!name) return;

      addLog(`Sending creation packet for: "${name}"...`, "muted");

      try {
        const res = await fetch(`${CMS_API}/projects/create`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name }),
        });

        if (res.ok) {
          const data = await res.json();
          addLog(`Success: Created project node ${data.id}.md`, "green");
          // Re-fetch registry
          const projectsRes = await fetch(`${CMS_API}/projects`);
          projects = await projectsRes.json();
          renderNodesList();

          // Select newly created project
          const newProj = projects.find((p) => p.id === data.id);
          if (newProj) selectProject(newProj);
        } else {
          const errData = await res.json();
          throw new Error(errData.error || "Failed to create");
        }
      } catch (err) {
        addLog(`Error creating file: ${err.message}`, "red");
      }
    });
  }

  // Initial check
  checkDaemonConnection();
</script>

<style>
  /* Access Shield Styles */
  .auth-shield {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 6rem 2rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-card-bg);
    border-radius: 4px;
    box-shadow: 0 0 30px rgba(239, 68, 68, 0.03);
    margin-top: 2rem;
  }
  .auth-box {
    max-width: 500px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .auth-box .text-red {
    color: var(--color-error);
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
  }
  .warning-glow {
    text-shadow: 0 0 10px rgba(239, 68, 68, 0.4);
  }
  .auth-title {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text);
  }
  .auth-desc {
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--color-muted);
  }
  .auth-back-link {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--color-accent);
    display: inline-block;
  }
  .auth-back-link:hover {
    color: var(--color-accent-glow);
    text-shadow: 0 0 8px rgba(139, 111, 196, 0.3);
  }

  .admin-container {
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  /* Header indicator lights */
  .admin-header {
    margin-bottom: 3rem;
  }
  .header-line {
    height: 2px;
    background: linear-gradient(to right, var(--color-accent), transparent);
    margin-bottom: 1rem;
  }
  .header-status-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .system-code {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }
  .daemon-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .indicator-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .indicator-dot.yellow {
